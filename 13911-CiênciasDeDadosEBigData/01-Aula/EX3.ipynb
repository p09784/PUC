   "source": [
    "Escreva um programa, que dado um númento inteiro n, imprima as triplas pitagóricas."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "404c5dff",
   "metadata": {},
   "outputs": [],
   "source": [
    "n = 5"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "2284e11a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "3 4 5\n"
     ]
    }
   ],
   "source": [
    "for a in range(1, n + 1):\n",
    "    for b in range(1, n + 1):\n",
    "        for c in range(1, n + 1):\n",
    "            if (a <= b <= c) and (a**2 + b**2 == c**2):\n",
    "                print(a, b, c)"
   ]
  }
 ],
